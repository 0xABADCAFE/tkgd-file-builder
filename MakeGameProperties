#!/usr/bin/php
<?php

declare(strict_types=1);

namespace TKG;
use stdClass;
use RuntimeException;

$aOpts = getopt('b:f:g:');
$sBase = $aOpts['b'] ?? throw new RuntimeException('Missing base location. Use -b<path to source dir>');
$sFrom = $aOpts['f'] ?? throw new RuntimeException('Missing from location. Use -f<path to source file>');
$sGame = $aOpts['g'] ?? throw new RuntimeException('Missing game location. Use -g<path to game dir>');

require 'src/bootstrap.php';

$oBuilder = new Mod\File\GameProperties\Builder(
    $sBase,
    $sFrom,
    $sGame
);

$oBuilder->build();

